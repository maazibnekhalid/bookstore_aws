# Copy to .env before running `npm run build`.
# Values come from `terraform output` in the terraform-bookstore project.

# Leave blank when serving through CloudFront. API calls will use relative
# /products and /orders paths routed by the same distribution.
VITE_API_BASE_URL=

# terraform output cognito_user_pool_id
VITE_COGNITO_USER_POOL_ID=us-east-1_example

# terraform output cognito_user_pool_client_id
VITE_COGNITO_CLIENT_ID=exampleclientid
